PORT=4000
# mongodb+srv (Atlas) SRV DNS hataları (querySrv ECONNREFUSED) — opsiyonel; virgül veya boşlukla ayırın
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

MONGO_URL=mongodb://localhost:27017/ai-automation
REDIS_URL=redis://localhost:6379
RABBIT_URL=amqp://localhost:5672

AUTH_REQUIRED=true
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret

GLOBAL_MAX_INFLIGHT=10
WORKER_PLUGIN_TIMEOUT_MS=0
STEP_LOCK_TTL_MS=60000
MAX_PAYLOAD_SIZE=1mb

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

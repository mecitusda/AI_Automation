{
  "name": "@aa/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "api": "npx nodemon apps/api/src/index.js",
    "web": "cd apps/web && npm run dev",
    "test:workflows": "node scripts/run-test-workflows.js",
    "test:openai": "node scripts/test-openai-plugin.js",
    "load-test:webhook": "node scripts/load-test-webhook.js",
    "test:success": "node scripts/success-basic-test.js",
    "test:http-error": "node scripts/http-step-error-test.js",
    "test:redact": "node scripts/redact-execution-params-test.js",
    "test:step-inputs": "node scripts/step-inputs-detail-test.js",
    "test:ai-invalid-json": "node scripts/ai-invalid-json-test.js",
    "test:ai-valid-json": "node scripts/ai-valid-json-test.js",
    "test:api-error": "node scripts/api-error-test.js",
    "test:timeout": "node scripts/timeout-test.js",
    "test:retry": "node scripts/retry-test.js",
    "test:rate-limit": "node scripts/rate-limit-test.js",
    "test:concurrency": "node scripts/concurrency-test.js",
    "test:large-payload": "node scripts/large-payload-test.js",
    "test:cancel": "node scripts/cancel-test.js",
    "test:all": "node scripts/run-all-tests.js",
    "test:all:strict": "cross-env STRICT_EXTENDED_TESTS=true node scripts/run-all-tests.js",
    "test:duplicate": "node scripts/duplicate-message-test.js",
    "test:auth-ownership": "node scripts/auth-ownership-test.js",
    "test:workflow-error-branch": "node scripts/workflow-error-branch-persist-test.js",
    "test:chaos:seeded": "node scripts/seeded-chaos-test.js",
    "test:soak:1h": "node scripts/soak-test.js",
    "test:soak:6h": "cross-env SOAK_DURATION_SEC=21600 node scripts/soak-test.js",
    "test:soak:24h": "cross-env SOAK_DURATION_SEC=86400 node scripts/soak-test.js"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "fast-xml-parser": "^5.7.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.16",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.14"
  }
}
